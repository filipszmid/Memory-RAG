# Copy this file to .env and fill in local credentials.

# --- Model Provider API Keys ---
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- LiteLLM Proxy & Dashboard Security ---
# Generate strong unique values before running Docker Compose or Kubernetes.
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
# Mode: DEV (Open Dashboard) or PRODUCTION (Password Protected)
LITELLM_MODE=PRODUCTION
# Database migration settings for fresh installs
USE_PRISMA_MIGRATE=True
STORE_MODEL_IN_DB=True
POSTGRES_PASSWORD=
LITELLM_DATABASE_URL=postgresql://postgres:replace_with_postgres_password@postgres-service:5432/litellm

# --- UI Dashboard Credentials ---
# Credentials used for both the LiteLLM dashboard and the Memory UI
UI_USERNAME=
UI_PASSWORD=
