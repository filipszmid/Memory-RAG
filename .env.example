# Copy this file to .env and fill in your details

# --- Model Provider API Keys ---
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- LiteLLM Proxy & Dashboard Security ---
# Master key for API access to the proxy
LITELLM_MASTER_KEY=sk-1234
# Salt for credential encryption
LITELLM_SALT_KEY=salt1234
# Mode: DEV (Open Dashboard) or PRODUCTION (Password Protected)
LITELLM_MODE=PRODUCTION
# Database migration settings for fresh installs
USE_PRISMA_MIGRATE=True
STORE_MODEL_IN_DB=True

# --- UI Dashboard Credentials ---
# Credentials used for both the LiteLLM dashboard and the Memory UI
UI_USERNAME=admin
UI_PASSWORD=admin1234
